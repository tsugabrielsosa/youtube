1) Instalamos Apache y MariaDB
sudo apt install apache2 mariadb-server -y

2) Agregamos repositorio para php

sudo apt install ca-certificates apt-transport-https software-properties-common
add-apt-repository ppa:ondrej/php

3) Realizamos actualizacion de paquetes
sudo apt update -y && sudo apt upgrade -y

4) Instalamos PHP 8.4 y extensionesZ
PHP8.4
sudo apt install php8.4 libapache2-mod-php8.4 php8.4-common php8.4-fpm php8.4-cgi php8.4-bcmath php8.4-gd php8.4-imap php8.4-intl php8.4-apcu php8.4-cli php8.4-mbstring php8.4-curl php8.4-mysql php8.4-xml unzip -y

5) comprobamos instalacion de php
php -v y reiniciamos apache sudo service apache2 restart

6)base de datos
sudo mysql -u root -p
CREATE DATABASE osticketdb;
grant all privileges on *.* to admin identified by '54203719' with grant option;
